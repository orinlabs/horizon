# OpenRouter API key — passed to every agent and the verifier via --ae / --ve.
# Get at https://openrouter.ai/keys.
OPENROUTER_API_KEY=sk-or-v1-...

# OpenRouter management key — required by all reference agents under agents/
# (trace_*, hermes, openclaw_lcm). Each trial uses it to mint a disposable
# sub-key with a $OPENROUTER_TRIAL_LIMIT_USD spend cap (default $20) so trials
# are cost-isolated and auditable. Get from OpenRouter dashboard → Settings →
# Keys → Create Management Key. This is a SEPARATE credential from your
# regular API key. Not needed for built-in Harbor agents like terminus-2.
OPENROUTER_MANAGEMENT_KEY=sk-or-v1-...

# Optional. Per-trial sub-key spend cap in USD. Defaults to 20.
# OPENROUTER_TRIAL_LIMIT_USD=20

# Required if running on Daytona (-e daytona). Get at app.daytona.io.
DAYTONA_API_KEY=dtn_...
