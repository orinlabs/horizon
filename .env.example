# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional. Defaults to openai/gpt-4o-mini. Any OpenRouter model id works,
# e.g. anthropic/claude-sonnet-4.5, openai/gpt-5, google/gemini-2.5-pro.
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Required to build any eval container: each eval's Dockerfile fetches its
# own trace.jsonl from the private dataset orinlabs/horizon-1-eval-traces
# at build time using a BuildKit secret. Create at
# https://huggingface.co/settings/tokens (Read access to orinlabs is enough).
HF_TOKEN=hf_...
